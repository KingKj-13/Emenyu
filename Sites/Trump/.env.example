# Runtime
NODE_ENV=production
TRUMP_APP_NAME=emenuy-trump
TRUMP_HOST=0.0.0.0
TRUMP_PORT=3012
TRUMP_RESTAURANT_ID=trump
TRUMP_PUBLIC_BASE_PATH=/Trump
TRUMP_PUBLIC_ORIGIN=https://your-domain.example
TRUMP_ALLOWED_ORIGINS=https://your-domain.example
TRUMP_TRUST_PROXY=true

# Secrets and seed accounts
# Generate with: openssl rand -base64 48
TRUMP_SESSION_SECRET=
TRUMP_SESSION_COOKIE_NAME=trump_session
TRUMP_SESSION_TTL_HOURS=12
TRUMP_OWNER_USER=owner
TRUMP_OWNER_PASS=
TRUMP_ADMIN_PASS=
TRUMP_MANAGER_USER=manager
TRUMP_MANAGER_PASS=
TRUMP_WAITER_USER=waiter
TRUMP_WAITER_PASS=

# Security controls
TRUMP_SECURE_COOKIES=true
TRUMP_HSTS_ENABLED=true
TRUMP_FORCE_HTTPS=false
TRUMP_RATE_LIMIT_WINDOW_MS=900000
TRUMP_RATE_LIMIT_MAX=600
TRUMP_AUTH_RATE_LIMIT_MAX=20
TRUMP_BODY_LIMIT=2mb
TRUMP_URLENCODED_LIMIT=1mb
TRUMP_UPLOAD_MAX_MB=25
TRUMP_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm
TRUMP_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.webp,.gif,.mp4,.webm

# Static asset and compression behavior
TRUMP_STATIC_CACHE_SECONDS=604800
TRUMP_COMPRESSION_THRESHOLD_BYTES=1024

# Logging
LOG_LEVEL=info

# PM2 tuning
PM2_MAX_MEMORY_RESTART=512M
PM2_KILL_TIMEOUT_MS=10000
PM2_LISTEN_TIMEOUT_MS=10000
PM2_MIN_UPTIME=10s
PM2_MAX_RESTARTS=10

# Optional legacy Python/AI settings used by local helper scripts
AssistantVoice=
InputLanguage=
GROQ_API_KEY=
